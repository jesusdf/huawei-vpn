# Copy this file to .env and fill in your own values.
# .env is git-ignored and must never be committed.

# VPN gateway address (IP or hostname) and port (SSL VPN default is 443).
VPN_GATEWAY=vpn.example.com
VPN_PORT=443

# Credentials.
VPN_USERNAME=my-user
VPN_PASSWORD=my-password

# Optional.
# TUN_DEVICE=cnem_vnic         # VPN interface name inside the container (max 9 chars, e.g. tun17)
# TZ=Europe/Madrid
